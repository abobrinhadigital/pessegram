# Configuração dos bots para Pessegram 4.0.0
# Copiar para .env e preencher os valores

# === Tokens dos Bots (criar via @BotFather) ===
TELEGRAM_BOT_TOKEN=""          # Chatbot (existente)
GOIABOOKLM_BOT_TOKEN=""        # GoiabookLM (novo)
MANGOFIER_BOT_TOKEN=""         # Mangofier (novo)

# === Gemini AI (para Chatbot) ===
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-2.5-flash-lite"

# === IDs ===
MASTER_USER_ID=""

# === API Router ===
LISTENER_API_TOKEN=""
LISTENER_API_PORT="7355"

# === GoiabookLM Integration ===
GOIABOOK_API_URL=""
GOIABOOK_API_TOKEN=""

# === Mangofier Integration ===
MANGOFIER_API_URL=""
MANGOFIER_API_TOKEN=""

# === Cloudflare Tunnel ===
CLOUDFLARE_TUNNEL_ID=""
CLOUDFLARE_DOMAIN="pessegram.mogami.dev.br"
