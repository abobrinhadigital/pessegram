#!/usr/bin/env ruby
# frozen_string_literal: true

require 'bundler/setup'
require_relative '../lib/pessegram'

begin
  Pessegram::CLI.start(ARGV)
rescue Interrupt
  puts "\nDesligando Pollux... O caos continuará sem mim."
  exit 0
rescue StandardError => e
  puts "\n[ERRO CATASTRÓFICO]: #{e.message}"
  exit 1
end
