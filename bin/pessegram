#!/usr/bin/env ruby
# frozen_string_literal: true

require 'bundler/setup'
require_relative '../lib/pessegram'

# Capturando os sinais de morte do teclado (INT/Ctrl+C) e do systemd (TERM)
%w[INT TERM].each do |signal|
  Signal.trap(signal) do
    puts "\nRecebi o sinal #{signal}. Desligando Pollux graciosamente... O caos continuará sem mim."
    Pessegram::ApiListener.stop
    sleep 1 # Tempo para a porta ser liberada
    exit 0
  end
end

begin
  Pessegram::CLI.start(ARGV)
rescue StandardError => e
  puts "\n[ERRO CATASTRÓFICO]: #{e.message}"
  exit 1
end